# Copy this file to .env and fill in your values.
# .env is gitignored.

# AWS region (your other instance is in us-east-2 / Ohio)
AWS_DEFAULT_REGION=us-east-2

# AWS credentials — only needed if running CloudWatch publishing locally.
# In EC2, prefer attaching an IAM role and leaving these blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Model serving threshold (tune after training based on PR curve)
THRESHOLD=0.5

# MLflow tracking
MLFLOW_TRACKING_URI=http://mlflow:5000

# Optional: alert email for SNS (not auto-wired; manual setup in AWS console)
ALERT_EMAIL=
